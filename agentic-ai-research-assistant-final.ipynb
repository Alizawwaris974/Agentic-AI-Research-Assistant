s","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T21:21:19.766667Z","iopub.execute_input":"2026-06-25T21:21:19.767015Z","iopub.status.idle":"2026-06-25T21:21:23.932037Z","shell.execute_reply.started":"2026-06-25T21:21:19.766986Z","shell.execute_reply":"2026-06-25T21:21:23.930944Z"}},"outputs":[{"name":"stdout","text":"Requirement already satisfied: ddgs in /usr/local/lib/python3.12/dist-packages (9.14.4)\nRequirement already satisfied: click>=8.1.8 in /usr/local/lib/python3.12/dist-packages (from ddgs) (8.3.2)\nRequirement already satisfied: primp>=1.2.3 in /usr/local/lib/python3.12/dist-packages (from ddgs) (1.3.1)\nRequirement already satisfied: lxml>=4.9.4 in /usr/local/lib/python3.12/dist-packages (from ddgs) (6.0.3)\nRequirement already satisfied: httpx>=0.28.1 in /usr/local/lib/python3.12/dist-packages (from httpx[brotli,http2,socks]>=0.28.1->ddgs) (0.28.1)\nRequirement already satisfied: fake-useragent>=2.2.0 in /usr/local/lib/python3.12/dist-packages (from ddgs) (2.2.0)\nRequirement already satisfied: anyio in /usr/local/lib/python3.12/dist-packages (from httpx>=0.28.1->httpx[brotli,http2,socks]>=0.28.1->ddgs) (4.13.0)\nRequirement already satisfied: certifi in /usr/local/lib/python3.12/dist-packages (from httpx>=0.28.1->httpx[brotli,http2,socks]>=0.28.1->ddgs) (2026.2.25)\nRequirement already satisfied: httpcore==1.* in /usr/local/lib/python3.12/dist-packages (from httpx>=0.28.1->httpx[brotli,http2,socks]>=0.28.1->ddgs) (1.0.9)\nRequirement already satisfied: idna in /usr/local/lib/python3.12/dist-packages (from httpx>=0.28.1->httpx[brotli,http2,socks]>=0.28.1->ddgs) (3.11)\nRequirement already satisfied: h11>=0.16 in /usr/local/lib/python3.12/dist-packages (from httpcore==1.*->httpx>=0.28.1->httpx[brotli,http2,socks]>=0.28.1->ddgs) (0.16.0)\nRequirement already satisfied: brotli in /usr/local/lib/python3.12/dist-packages (from httpx[brotli,http2,socks]>=0.28.1->ddgs) (1.2.0)\nRequirement already satisfied: h2<5,>=3 in /usr/local/lib/python3.12/dist-packages (from httpx[brotli,http2,socks]>=0.28.1->ddgs) (4.3.0)\nRequirement already satisfied: socksio==1.* in /usr/local/lib/python3.12/dist-packages (from httpx[brotli,http2,socks]>=0.28.1->ddgs) (1.0.0)\nRequirement already satisfied: hyperframe<7,>=6.1 in /usr/local/lib/python3.12/dist-packages (from h2<5,>=3->httpx[brotli,http2,socks]>=0.28.1->ddgs) (6.1.0)\nRequirement already satisfied: hpack<5,>=4.1 in /usr/local/lib/python3.12/dist-packages (from h2<5,>=3->httpx[brotli,http2,socks]>=0.28.1->ddgs) (4.1.0)\nRequirement already satisfied: typing_extensions>=4.5 in /usr/local/lib/python3.12/dist-packages (from anyio->httpx>=0.28.1->httpx[brotli,http2,socks]>=0.28.1->ddgs) (4.15.0)\n","output_type":"stream"}],"execution_count":6},{"id":"5315f348","cell_type":"code","source":"# %% Cell 5: Tool definitions\nimport ast\nimport io\nimport contextlib\nimport concurrent.futures\nimport math\nimport statistics\nimport json as json_module\nimport re as re_module\nfrom langchain_core.tools import tool\n#from duckduckgo_search import DDGS\n\n# ── Tool 1: Web Search (DuckDuckGo, free, no API key) ──────────────────\nimport datetime as _dt\n\ntry:\n    from ddgs import DDGS  # the package was renamed from duckduckgo_search -> ddgs\nexcept ImportError:\n    from duckduckgo_search import DDGS\n\n@tool\ndef web_search(query: str) -> str:\n    '''Search the live web for recent facts, news, papers, or events.\n    Returns up to 4 results with title, a short snippet, and URL.'''\n    try:\n        with DDGS() as ddgs:\n            results = list(ddgs.text(query, max_results=4))\n        if not results:\n            return \"No web results found.\"\n        lines = [f\"(search performed on {_dt.date.today().isoformat()} — use this for any 'latest'/'current' framing)\"]\n        for i, r in enumerate(results, 1):\n            title = r.get('title', '')[:120]\n            body = r.get('body', '')[:280]\n            lines.append(f\"[{i}] {title}\\n{body}\\nURL: {r.get('href', '')}\")\n        return \"\\n\\n\".join(lines)\n    except Exception as e:\n        return f\"Web search error: {e}\"\n\n# ── Tool 2: RAG Retrieval (local ChromaDB corpus) ───────────────────────\n@tool\ndef rag_retrieval(query: str) -> str:\n    '''Retrieve relevant passages from the local research knowledge base\n    (curated notes on agentic-AI, RAG, transformers, evaluation, etc.).'''\n    docs = retriever.invoke(query)\n    if not docs:\n        return \"No relevant documents found in local corpus.\"\n    out = []\n    for i, doc in enumerate(docs, 1):\n        source = doc.metadata.get(\"source\", \"unknown\")\n        out.append(f\"[{i}] Source: {source}\\n{doc.page_content[:600]}\")\n    return \"\\n\\n\".join(out)\n\n# ── Tool 3: Code Execution (AST allow-list + restricted globals + timeout)\n_ALLOWED_NODE_TYPES = (\n    ast.Module, ast.Expr, ast.Load, ast.Store, ast.Name, ast.Constant,\n    ast.Assign, ast.AugAssign, ast.BinOp, ast.UnaryOp, ast.BoolOp, ast.Compare,\n    ast.Call, ast.keyword, ast.Attribute, ast.Subscript, ast.Index,\n    ast.List, ast.Tuple, ast.Dict, ast.Set, ast.Slice,\n    ast.For, ast.While, ast.If, ast.Break, ast.Continue, ast.Pass,\n    ast.FunctionDef, ast.Return, ast.Lambda, ast.arguments, ast.arg,\n    ast.comprehension, ast.ListComp, ast.DictComp, ast.SetComp, ast.GeneratorExp,\n    ast.Add, ast.Sub, ast.Mult, ast.Div, ast.Mod, ast.Pow, ast.FloorDiv,\n    ast.And, ast.Or, ast.Not, ast.Eq, ast.NotEq, ast.Lt, ast.LtE, ast.Gt, ast.GtE,\n    ast.In, ast.NotIn, ast.USub, ast.UAdd, ast.Is, ast.IsNot,\n    ast.JoinedStr, ast.FormattedValue, ast.IfExp, ast.Starred,\n)\n_FORBIDDEN_NAMES = {\n    \"__import__\", \"open\", \"exec\", \"eval\", \"compile\", \"input\", \"globals\",\n    \"locals\", \"vars\", \"dir\", \"getattr\", \"setattr\", \"delattr\", \"__builtins__\",\n    \"breakpoint\", \"help\",\n}\n\ndef _ast_is_safe(code: str) -> tuple[bool, str]:\n    try:\n        tree = ast.parse(code, mode=\"exec\")\n    except SyntaxError as e:\n        return False, f\"Syntax error: {e}\"\n    for node in ast.walk(tree):\n        if isinstance(node, (ast.Import, ast.ImportFrom)):\n            return False, \"Imports are not allowed inside code_executor.\"\n        if not isinstance(node, _ALLOWED_NODE_TYPES):\n            return False, f\"Disallowed syntax: {type(node).__name__}\"\n        if isinstance(node, ast.Name) and node.id in _FORBIDDEN_NAMES:\n            return False, f\"Use of '{node.id}' is not allowed.\"\n        if isinstance(node, ast.Attribute) and node.attr.startswith(\"__\"):\n            return False, \"Access to dunder attributes is not allowed.\"\n    return True, \"\"\n\nimport builtins as _builtins_module\n_ALLOWED_BUILTIN_NAMES = [\n    \"abs\", \"all\", \"any\", \"bool\", \"dict\", \"enumerate\", \"float\",\n    \"int\", \"len\", \"list\", \"max\", \"min\", \"print\", \"range\",\n    \"round\", \"set\", \"sorted\", \"str\", \"sum\", \"tuple\", \"zip\", \"type\",\n]\n_SAFE_BUILTINS = {name: getattr(_builtins_module, name) for name in _ALLOWED_BUILTIN_NAMES}\n\ndef _run_code(code: str) -> str:\n    safe_globals = {\n        \"__builtins__\": _SAFE_BUILTINS,\n        \"math\": math, \"statistics\": statistics,\n        \"json\": json_module, \"re\": re_module,\n    }\n    safe_locals: dict = {}\n    buf = io.StringIO()\n    with contextlib.redirect_stdout(buf):\n        exec(compile(code, \"<code_executor>\", \"exec\"), safe_globals, safe_locals)\n    out = buf.getvalue()\n    if \"result\" in safe_locals:\n        out += f\"\\nresult = {safe_locals['result']!r}\"\n    return out or \"(code ran with no output — assign to a variable named `result` to return a value)\"\n\n@tool\ndef code_executor(code: str) -> str:\n    '''Execute a restricted subset of Python (no imports, no file/network/\n    OS access) for calculations, data transforms, or quick analysis.\n    Assign your answer to a variable named `result` to have it returned.\n    Times out after 5 seconds.'''\n    safe, reason = _ast_is_safe(code)\n    if not safe:\n        return f\"Rejected: {reason}\"\n    with concurrent.futures.ThreadPoolExecutor(max_workers=1) as pool:\n        future = pool.submit(_run_code, code)\n        try:\n            return future.result(timeout=5)\n        except concurrent.futures.TimeoutError:\n            return \"Execution error: timed out after 5 seconds.\"\n        except Exception as e:\n            return f\"Execution error: {e}\"\n\n# ── Tool 4: Summariser (provider-agnostic LLM via build_llm()) ─────────\n_summary_llm = build_llm(max_tokens=512, disable_thinking=True)\n\n@tool\ndef summarise_text(text: str, style: str = \"bullet\") -> str:\n    '''Summarise a long piece of text. style: 'bullet' | 'paragraph' | 'table'.'''\n    prompt = (\n        f\"Summarise the following text in {style} format. \"\n        f\"Be concise and accurate:\\n\\n{text[:4000]}\"\n    )\n    return _summary_llm.invoke(prompt).content\n\nTOOLS = [web_search, rag_retrieval, code_executor, summarise_text]\nprint(f\"🔧 {len(TOOLS)} tools ready: {[t.name for t in TOOLS]}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T21:22:52.191907Z","iopub.execute_input":"2026-06-25T21:22:52.192268Z","iopub.status.idle":"2026-06-25T21:22:55.250181Z","shell.execute_reply.started":"2026-06-25T21:22:52.192237Z","shell.execute_reply":"2026-06-25T21:22:55.249272Z"}},"outputs":[{"name":"stdout","text":"🔧 4 tools ready: ['web_search', 'rag_retrieval', 'code_executor', 'summarise_text']\n","output_type":"stream"}],"execution_count":8},{"id":"bae8034b","cell_type":"markdown","source":"## Cell 6 — LangGraph ReAct Agent (`create_react_agent` + `MemorySaver`)","metadata":{}},{"id":"15c1ead8","cell_type":"code","source":"# %% Cell 6: LangGraph agent\nfrom langgraph.prebuilt import create_react_agent\nfrom langgraph.checkpoint.memory import MemorySaver\nfrom langchain_core.messages import HumanMessage\n\nllm = build_llm(streaming=True, max_tokens=1024, with_retry=False)  # create_react_agent needs .bind_tools(); retry handled at the graph-invocation level (Cell 7 / Cell 9)\n\nSYSTEM_PROMPT = '''You are an expert AI research assistant with access to 4 tools:\n1. web_search — for live web information (recent events, news)\n2. rag_retrieval — for the local knowledge base (agentic-AI / LLM concepts)\n3. code_executor — to run restricted Python for analysis and calculations\n4. summarise_text — to condense long content\n\nStrategy:\n- Check the local knowledge base (rag_retrieval) FIRST for conceptual / definitional questions.\n- Use web_search for anything time-sensitive or outside the local corpus.\n- For multi-hop questions, break them into sub-questions and call tools sequentially.\n- Use code_executor for any numerical analysis.\n- Always cite which tool/source a fact came from in your final answer.\n- Never fabricate — if you don't know, say so and suggest where to look.\n'''\n\nmemory = MemorySaver()\nagent_graph = create_react_agent(\n    llm,\n    tools=TOOLS,\n    prompt=SYSTEM_PROMPT,\n    checkpointer=memory,\n)\n\nprint(\"✅ Agent graph compiled with MemorySaver checkpointing.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T21:22:55.251951Z","iopub.execute_input":"2026-06-25T21:22:55.252256Z","iopub.status.idle":"2026-06-25T21:22:55.802335Z","shell.execute_reply.started":"2026-06-25T21:22:55.252228Z","shell.execute_reply":"2026-06-25T21:22:55.801369Z"}},"outputs":[{"name":"stdout","text":"✅ Agent graph compiled with MemorySaver checkpointing.\n","output_type":"stream"},{"name":"stderr","text":"/tmp/ipykernel_58/2620412618.py:24: LangGraphDeprecatedSinceV10: create_react_agent has been moved to `langchain.agents`. Please update your import to `from langchain.agents import create_agent`. Deprecated in LangGraph V1.0 to be removed in V2.0.\n  agent_graph = create_react_agent(\n","output_type":"stream"}],"execution_count":9},{"id":"42e9c1c5","cell_type":"markdown","source":"## Cell 7 — Test the Agent (3 sample queries)","metadata":{}},{"id":"63fc0635","cell_type":"code","source":"# %% Cell 7: Smoke-test the agent\nimport time\nimport uuid\n\ndef run_agent_sync(query: str, session_id: str) -> str:\n    '''The agent's model (Cell 6) is intentionally NOT wrapped in .with_retry()\n    — create_react_agent needs to call .bind_tools() on it directly, which\n    a retry-wrapped Runnable doesn't expose. This try/except is the safety\n    net for that model instead: a transient failure here returns a readable\n    message rather than crashing the cell. get_message_text() normalizes\n    .content, which can be a plain string or a list of structured parts\n    depending on the provider.'''\n    config = {\"configurable\": {\"thread_id\": session_id}, \"recursion_limit\": 25}\n    try:\n        result = agent_graph.invoke({\"messages\": [HumanMessage(content=query)]}, config=config)\n        return get_message_text(result[\"messages\"][-1].content)\n    except Exception as e:\n        return f\"⚠️ Agent call failed after retries: {e}\"\n\nsample_queries = [\n    \"What is ReAct and how does it relate to tool use in LLM agents?\",\n    \"Compute the factorial of 12 and tell me what RAG stands for.\",\n    \"What's the latest news about Anthropic's Claude models?\",\n]\n\ntest_session = str(uuid.uuid4())\nfor q in sample_queries:\n    print(\"=\" * 70)\n    print(\"Q:\", q)\n    print(\"-\" * 70)\n    print(run_agent_sync(q, test_session)[:1200])\n    print()\n    time.sleep(2)  # stay comfortably under the active provider's requests-per-minute cap\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T21:22:55.803256Z","iopub.execute_input":"2026-06-25T21:22:55.803565Z","iopub.status.idle":"2026-06-25T21:26:41.836525Z","shell.execute_reply.started":"2026-06-25T21:22:55.803527Z","shell.execute_reply":"2026-06-25T21:26:41.835448Z"}},"outputs":[{"name":"stdout","text":"======================================================================\nQ: What is ReAct and how does it relate to tool use in LLM agents?\n----------------------------------------------------------------------\nReAct (Reason + Act) is a pattern that interleaves chain-of-thought reasoning steps with discrete tool-calling actions [1]. In this approach, a language model reasons about what information it needs, calls a tool to obtain that information, observes the result, and then repeats the process. This method grounds the model's reasoning in real, verifiable information rather than relying solely on its internal knowledge [1].\n\nReAct relates to tool use in LLM agents by providing a structured way for agents to interact with external systems and data. Modern LLMs can be equipped with structured tool schemas (including name, description, and JSON parameters) and can choose to emit a structured tool call instead of free text [2]. The host application then executes this function and feeds the result back to the model, enabling the LLM agent to interact with live systems and data [2]. ReAct essentially describes the *strategy* an LLM agent employs to leverage these tools effectively.\n\n======================================================================\nQ: Compute the factorial of 12 and tell me what RAG stands for.\n----------------------------------------------------------------------\n**Factorial of 12:** 479,001,600 (computed via a simple loop).\n\n**RAG:** Retrieval‑Augmented Generation – a framework that couples a retriever (e.g., a vector‑search over an embedding index) with a generative LLM so the model can incorporate retrieved passages as context, reducing hallucination and enabling citation of up‑to‑date or domain‑specific information [1].\n\n======================================================================\nQ: What's the latest news about Anthropic's Claude models?\n----------------------------------------------------------------------\n**Recent developments (as of June 2026) for Anthropic’s Claude family**\n\n| Date (approx.) | Announcement / Update | Key points |\n|----------------|-----------------------|------------|\n| **2 days ago** – Anthropic newsroom | *Upgrade to the Opus class (often referred to as “Claude 4”) and launch of “Project Glasswing.”* | – The Opus‑class models now have stronger performance on coding, agentic (tool‑use) tasks, and professional‑work workloads.<br>– “Project Glasswing” adds a consistency layer that lets the model maintain reliable behavior over long‑running, multi‑step processes (e.g., complex reasoning or tool‑calling pipelines). |\n| **2 weeks ago** – Model‑family timeline site (hidekazu‑konishi.com) | *Claude 4 (Opus) released in May 2025, with subsequent incremental upgrades.* | – The timeline confirms that Claude 4 is the current flagship model, offering a larger context window (up to 200 k tokens) and higher‑capacity architecture compared with Claude 3 Opus (released March 2024). |\n| **17 hours ago** – Wikipedia entry on Anthropic | *Anthropic added new API capabilities, notably the Model Context Protocol (MCP) connector.* | – MCP lets developers stream external context (e.g., \n\n","output_type":"stream"}],"execution_count":10},{"id":"8fa1d97b","cell_type":"markdown","source":"## Cell 8 — Mini Evaluation (20-question benchmark, LLM-as-judge)\n\nThe original 200-question HotpotQA-style benchmark is impractical to run repeatedly on a free-tier API. This 20-question mini-benchmark covers the local corpus topics plus a couple of arithmetic / multi-hop questions, scored by the same free LLM (via `build_llm()`) acting as judge.","metadata":{}},{"id":"1ef25bf9","cell_type":"code","source":"# %% Cell 8: Mini evaluation\nMINI_BENCHMARK = [\n    {\"question\": \"What does RAG stand for and what problem does it solve?\",\n     \"gold_answer\": \"Retrieval-Augmented Generation; it grounds LLM generation in retrieved documents to reduce hallucination.\"},\n    {\"question\": \"What is the ReAct pattern?\",\n     \"gold_answer\": \"Interleaving reasoning steps with tool-calling actions, observing results, and repeating.\"},\n    {\"question\": \"What hardware does Groq use for fast inference?\",\n     \"gold_answer\": \"A custom Language Processing Unit (LPU).\"},\n    {\"question\": \"What is multi-head attention?\",\n     \"gold_answer\": \"Splitting attention into several parallel heads that each learn different relationships, then concatenating results.\"},\n    {\"question\": \"Why use MMR instead of plain similarity search for retrieval?\",\n     \"gold_answer\": \"MMR balances relevance with diversity, avoiding near-duplicate retrieved passages.\"},\n    {\"question\": \"What is prompt injection?\",\n     \"gold_answer\": \"Untrusted content crafted to hijack an agent's instructions; agents should treat tool/web content as data, not commands.\"},\n    {\"question\": \"What does a LangGraph checkpointer do?\",\n     \"gold_answer\": \"Persists agent state keyed by a thread/session id so multi-turn conversations can resume without resending full history.\"},\n    {\"question\": \"What's 17 times 23, computed precisely?\",\n     \"gold_answer\": \"391\"},\n    {\"question\": \"What is the purpose of CORS in a web API?\",\n     \"gold_answer\": \"Controls which external origins may call the API from browser JavaScript.\"},\n    {\"question\": \"What does SSE stand for and why is it used for LLM streaming?\",\n     \"gold_answer\": \"Server-Sent Events; lightweight one-directional push protocol over HTTP, good for streaming tokens to a browser.\"},\n    {\"question\": \"What is the difference between fine-tuning and in-context learning?\",\n     \"gold_answer\": \"Fine-tuning updates model weights on task data; in-context learning adapts behaviour via prompt/context only, no weight updates.\"},\n    {\"question\": \"What is a multi-hop question?\",\n     \"gold_answer\": \"A question requiring chaining several individually retrievable facts together rather than one passage.\"},\n    {\"question\": \"What does a recursion limit protect against in an agent loop?\",\n     \"gold_answer\": \"Prevents the agent from looping indefinitely by forcing it to stop and return its best answer after N steps.\"},\n    {\"question\": \"What is hallucination in the context of LLMs?\",\n     \"gold_answer\": \"Generating fluent but factually incorrect or unsupported statements.\"},\n    {\"question\": \"What does RLHF use a reward model for?\",\n     \"gold_answer\": \"Trained on human preference comparisons, then used to optimise the policy model via reinforcement learning (e.g. PPO).\"},\n    {\"question\": \"Compute the sum of the first 10 positive integers using code, then state the result.\",\n     \"gold_answer\": \"55\"},\n    {\"question\": \"What is the role of ngrok in this project's architecture?\",\n     \"gold_answer\": \"Exposes the local/Kaggle FastAPI server at a public HTTPS URL so n8n can reach it.\"},\n    {\"question\": \"Why was MiniLM chosen as the embedding model here instead of an OpenAI embedding model?\",\n     \"gold_answer\": \"It's free, runs locally on CPU, and is fast — avoiding paid API dependency.\"},\n    {\"question\": \"What does 'temperature' control during text generation?\",\n     \"gold_answer\": \"The randomness of next-token sampling; lower is more deterministic, higher is more diverse.\"},\n    {\"question\": \"What must happen to a vector store if you change embedding models?\",\n     \"gold_answer\": \"It must be fully rebuilt/re-indexed, since old and new vectors aren't comparable.\"},\n]\n\nimport time\nimport re as _re_judge\n\n# max_tokens=10 here previously caused every single judge call to silently\n# fail: gemini-2.5-flash / gpt-oss-120b are reasoning models that spend part\n# of their output budget on hidden chain-of-thought before the visible\n# answer, so a 10-token budget got consumed entirely by that hidden\n# reasoning and the visible text was empty — `.startswith(\"YES\")` then\n# always returned False, with no exception raised anywhere. Fixed by (a)\n# disabling hidden reasoning for this simple classification call via\n# disable_thinking=True, and (b) raising max_tokens as a second line of\n# defense regardless.\njudge_llm = build_llm(max_tokens=300, disable_thinking=True)\n\ndef judge_answer(question: str, gold: str, predicted: str) -> bool:\n    judge_prompt = (\n        f\"Question: {question}\\nGold answer: {gold}\\nPredicted answer: {predicted}\\n\\n\"\n        \"Does the predicted answer correctly capture the key fact(s) in the gold answer? \"\n        \"Do not explain your reasoning. Respond with only the single word YES or NO.\"\n    )\n    raw = get_message_text(judge_llm.invoke(judge_prompt).content).strip().upper()\n    # Take the LAST standalone YES/NO in the text rather than requiring it to\n    # be the very first token — robust even if a stray reasoning fragment\n    # leaks through before the actual verdict.\n    matches = _re_judge.findall(r\"\\bYES\\b|\\bNO\\b\", raw)\n    return matches[-1] == \"YES\" if matches else False\n\ndef run_mini_eval():\n    correct = 0\n    rows = []\n    for item in MINI_BENCHMARK:\n        sid = str(uuid.uuid4())\n        try:\n            predicted = run_agent_sync(item[\"question\"], sid)\n        except Exception as e:\n            predicted = f\"<error: {e}>\"\n        is_correct = False\n        try:\n            is_correct = judge_answer(item[\"question\"], item[\"gold_answer\"], predicted)\n        except Exception as e:\n            print(f\"  ⚠️ Judge call failed for {item['question']!r}: {e}\")\n        correct += int(is_correct)\n        rows.append((item[\"question\"], is_correct))\n        time.sleep(1.5)  # be gentle on free-tier requests-per-minute caps (each question = 2 calls: agent + judge)\n    accuracy = correct / len(MINI_BENCHMARK)\n    print(f\"\\nMini-benchmark accuracy: {correct}/{len(MINI_BENCHMARK)} = {accuracy:.0%}\")\n    for q, ok in rows:\n        print(f\"  {'✅' if ok else '❌'} {q}\")\n    return accuracy\n\n# Uncomment to run (takes ~1-2 minutes on free-tier APIs):\nrun_mini_eval()\nprint(\"ℹ️  Call run_mini_eval() to score the 20-question mini-benchmark.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T21:26:41.837733Z","iopub.execute_input":"2026-06-25T21:26:41.837995Z","iopub.status.idle":"2026-06-25T22:05:12.391048Z","shell.execute_reply.started":"2026-06-25T21:26:41.837969Z","shell.execute_reply":"2026-06-25T22:05:12.389707Z"}},"outputs":[{"name":"stdout","text":"\nMini-benchmark accuracy: 19/20 = 95%\n  ✅ What does RAG stand for and what problem does it solve?\n  ✅ What is the ReAct pattern?\n  ❌ What hardware does Groq use for fast inference?\n  ✅ What is multi-head attention?\n  ✅ Why use MMR instead of plain similarity search for retrieval?\n  ✅ What is prompt injection?\n  ✅ What does a LangGraph checkpointer do?\n  ✅ What's 17 times 23, computed precisely?\n  ✅ What is the purpose of CORS in a web API?\n  ✅ What does SSE stand for and why is it used for LLM streaming?\n  ✅ What is the difference between fine-tuning and in-context learning?\n  ✅ What is a multi-hop question?\n  ✅ What does a recursion limit protect against in an agent loop?\n  ✅ What is hallucination in the context of LLMs?\n  ✅ What does RLHF use a reward model for?\n  ✅ Compute the sum of the first 10 positive integers using code, then state the result.\n  ✅ What is the role of ngrok in this project's architecture?\n  ✅ Why was MiniLM chosen as the embedding model here instead of an OpenAI embedding model?\n  ✅ What does 'temperature' control during text generation?\n  ✅ What must happen to a vector store if you change embedding models?\nℹ️  Call run_mini_eval() to score the 20-question mini-benchmark.\n","output_type":"stream"}],"execution_count":11},{"id":"89f33f4f","cell_type":"markdown","source":"## Cell 9 — FastAPI App (CORS + streaming + session history)","metadata":{}},{"id":"85dce830","cell_type":"code","source":"# %% Cell 9: FastAPI app\nfrom fastapi import FastAPI, Request\nfrom fastapi.middleware.cors import CORSMiddleware\nfrom fastapi.responses import StreamingResponse, HTMLResponse, JSONResponse\nfrom pydantic import BaseModel\nimport json as _json\n\napp = FastAPI(title=\"Agentic AI Research Assistant\")\n\n# CORS — required for the n8n chat widget / any browser-based UI to call this API\napp.add_middleware(\n    CORSMiddleware,\n    allow_origins=[\"*\"],\n    allow_credentials=True,\n    allow_methods=[\"*\"],\n    allow_headers=[\"*\"],\n)\n\nclass QueryRequest(BaseModel):\n    query: str\n    session_id: str | None = None\n\n@app.get(\"/health\")\ndef health():\n    return {\"status\": \"ok\", \"provider\": LLM_PROVIDER, \"model\": AGENT_MODEL, \"tools\": [t.name for t in TOOLS]}\n\n@app.post(\"/research\")\nasync def research_endpoint(req: QueryRequest):\n    '''Non-streaming research endpoint — what n8n's HTTP Request node calls.'''\n    sid = req.session_id or str(uuid.uuid4())\n    config = {\"configurable\": {\"thread_id\": sid}, \"recursion_limit\": 25}\n    try:\n        result = await agent_graph.ainvoke(\n            {\"messages\": [HumanMessage(content=req.query)]}, config=config\n        )\n        answer = get_message_text(result[\"messages\"][-1].content)\n        return {\"session_id\": sid, \"answer\": answer}\n    except Exception as e:\n        # The agent's model (Cell 6) isn't wrapped in .with_retry() — see Cell 2 —\n        # so this is the actual safety net for that model: a clean JSON error\n        # instead of a 500 with a raw traceback (handy for n8n's error branch too).\n        return JSONResponse(\n            status_code=502,\n            content={\"session_id\": sid, \"error\": str(e), \"answer\": None},\n        )\n\n@app.get(\"/research/stream\")\nasync def research_stream(query: str, session_id: str | None = None):\n    '''SSE streaming endpoint — token-by-token output + tool-call events,\n    consumed by the HTML UI's EventSource.'''\n    sid = session_id or str(uuid.uuid4())\n    config = {\"configurable\": {\"thread_id\": sid}, \"recursion_limit\": 25}\n\n    async def event_generator():\n        yield f\"data: {_json.dumps({'type': 'start', 'session_id': sid})}\\n\\n\"\n        final_chunks = []\n        try:\n            async for event in agent_graph.astream_events(\n                {\"messages\": [HumanMessage(content=query)]},\n                config=config,\n                version=\"v2\",\n            ):\n                kind = event[\"event\"]\n                if kind == \"on_chat_model_stream\":\n                    chunk = event[\"data\"][\"chunk\"]\n                    content = get_message_text(getattr(chunk, \"content\", \"\"))\n                    if content:\n                        final_chunks.append(content)\n                        yield f\"data: {_json.dumps({'type': 'token', 'content': content})}\\n\\n\"\n                elif kind == \"on_tool_start\":\n                    yield f\"data: {_json.dumps({'type': 'tool_call', 'tool': event['name']})}\\n\\n\"\n                elif kind == \"on_tool_end\":\n                    out = event.get(\"data\", {}).get(\"output\")\n                    preview = get_message_text(getattr(out, \"content\", out))[:200]\n                    yield f\"data: {_json.dumps({'type': 'tool_done', 'tool': event['name'], 'preview': preview})}\\n\\n\"\n        except Exception as e:\n            yield f\"data: {_json.dumps({'type': 'error', 'message': str(e)})}\\n\\n\"\n\n        final_answer = \"\".join(final_chunks)\n        yield f\"data: {_json.dumps({'type': 'done', 'session_id': sid, 'answer': final_answer})}\\n\\n\"\n\n    return StreamingResponse(event_generator(), media_type=\"text/event-stream\")\n\n@app.get(\"/session/{session_id}/history\")\ndef get_history(session_id: str):\n    config = {\"configurable\": {\"thread_id\": session_id}}\n    try:\n        state = agent_graph.get_state(config)\n        msgs = state.values.get(\"messages\", [])\n    except Exception:\n        msgs = []\n    return {\n        \"session_id\": session_id,\n        \"turns\": len(msgs) // 2,\n        \"messages\": [\n            {\"role\": \"human\" if m.type == \"human\" else \"ai\", \"content\": get_message_text(m.content)}\n            for m in msgs if m.type in (\"human\", \"ai\") and m.content\n        ],\n    }\n\nprint(\"✅ FastAPI app defined: /health, /research, /research/stream, /session/{id}/history\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T22:05:12.393622Z","iopub.execute_input":"2026-06-25T22:05:12.393946Z","iopub.status.idle":"2026-06-25T22:05:12.651970Z","shell.execute_reply.started":"2026-06-25T22:05:12.393916Z","shell.execute_reply":"2026-06-25T22:05:12.651124Z"}},"outputs":[{"name":"stdout","text":"✅ FastAPI app defined: /health, /research, /research/stream, /session/{id}/history\n","output_type":"stream"}],"execution_count":12},{"id":"cf3047cf","cell_type":"markdown","source":"## Cell 10 — \"Field Notes\" Chat UI\n\nA self-contained HTML/CSS/JS chat interface, deliberately **not** another dark-glassmorphism panel. Since the product *is* a research tool, the UI borrows its visual language from an annotated research notebook:\n\n- **Palette**: warm paper (`#F6F1E7`), ink (`#26241F`), highlighter amber (`#D98E2B`) for the assistant, citation teal (`#2F6F62`) for tool activity.\n- **Type**: a serif display face for headings (literature-review feel) + a monospace face for tool-call traces and citation tags (data feel).\n- **Signature element**: a live **margin rail** of numbered citation/tool tags that animate in next to the transcript as the agent calls tools — mimicking footnotes accumulating down the side of a paper as you read it, instead of a generic \"thinking...\" spinner.\n\nThis is served at `GET /` by the FastAPI app, and the exact same file is also written to disk as a standalone `chat_ui.html` you can open by itself and point at any deployment URL.","metadata":{}},{"id":"9c623218","cell_type":"code","source":"# %% Cell 10: HTML chat UI\nCHAT_UI_HTML = r\"\"\"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Field Notes — Agentic Research Assistant</title>\n<style>\n  :root{\n    --paper:#F6F1E7; --paper-2:#EFE7D8; --ink:#26241F; --ink-soft:#5B5648;\n    --rule:#D9CFB8; --amber:#D98E2B; --amber-deep:#A8651A; --teal:#2F6F62;\n    --teal-soft:#E3EDE9; --card:#FFFDF8; --shadow: 0 1px 0 rgba(38,36,31,.06);\n  }\n  *{box-sizing:border-box;}\n  body{\n    margin:0; background:var(--paper); color:var(--ink);\n    font-family: 'Iowan Old Style','Source Serif 4', Georgia, serif;\n    -webkit-font-smoothing:antialiased;\n  }\n  .mono{ font-family:'JetBrains Mono','SF Mono',Consolas,monospace; }\n  header{\n    padding:28px 32px 18px; border-bottom:2px solid var(--ink);\n    display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:8px;\n  }\n  header h1{ font-size:1.5rem; margin:0; letter-spacing:.2px; }\n  header .meta{ font-family:'JetBrains Mono',monospace; font-size:.72rem; color:var(--ink-soft); text-transform:uppercase; letter-spacing:.08em;}\n  .layout{\n    display:grid; grid-template-columns: 1fr 230px; gap:0; max-width:1180px; margin:0 auto;\n    min-height: calc(100vh - 96px);\n  }\n  @media (max-width: 800px){ .layout{ grid-template-columns: 1fr; } .rail{ display:none; } }\n\n  .transcript{ padding:24px 32px 130px; overflow-y:auto; }\n  .starter-row{ display:flex; gap:10px; flex-wrap:wrap; margin-bottom:22px; }\n  .starter{\n    background:var(--card); border:1px solid var(--rule); border-radius:3px;\n    padding:9px 13px; font-size:.82rem; cursor:pointer; color:var(--ink-soft);\n    font-family:'JetBrains Mono',monospace; transition:.15s;\n  }\n  .starter:hover{ border-color:var(--amber-deep); color:var(--ink); }\n\n  .msg{ margin:0 0 22px; max-width: 72ch; animation: fadeIn .25s ease; }\n  @keyframes fadeIn{ from{opacity:0; transform:translateY(4px);} to{opacity:1; transform:none;} }\n  .msg .role{\n    font-family:'JetBrains Mono',monospace; font-size:.68rem; letter-spacing:.1em;\n    text-transform:uppercase; color:var(--ink-soft); margin-bottom:4px; display:block;\n  }\n  .msg.user .role{ color:var(--teal); }\n  .msg.assistant .role{ color:var(--amber-deep); }\n  .msg .bubble{ font-size:1.04rem; line-height:1.6; white-space:pre-wrap; }\n  .msg.user .bubble{ padding-left:14px; border-left:3px solid var(--teal); }\n  .msg.assistant .bubble{ padding-left:14px; border-left:3px solid var(--amber); }\n\n  .typing{ display:inline-flex; gap:4px; padding-left:14px; }\n  .typing span{ width:5px; height:5px; border-radius:50%; background:var(--amber-deep); animation: bounce 1.1s infinite ease-in-out; }\n  .typing span:nth-child(2){ animation-delay:.15s; } .typing span:nth-child(3){ animation-delay:.3s; }\n  @keyframes bounce{ 0%,80%,100%{ transform:translateY(0); opacity:.4;} 40%{ transform:translateY(-4px); opacity:1; } }\n\n  .composer{\n    position:fixed; bottom:0; left:0; right:0; background:linear-gradient(180deg, transparent, var(--paper) 35%);\n    padding:22px 0 26px;\n  }\n  .composer-inner{ max-width:1180px; margin:0 auto; padding:0 32px; display:grid; grid-template-columns:1fr 230px; gap:0; }\n  .composer form{\n    grid-column:1; display:flex; gap:10px; background:var(--card); border:1px solid var(--ink);\n    border-radius:4px; padding:6px 6px 6px 16px; box-shadow:0 2px 10px rgba(38,36,31,.08);\n  }\n  .composer input[type=text]{\n    flex:1; border:none; outline:none; background:transparent; font-size:1rem;\n    font-family:inherit; color:var(--ink); padding:10px 0;\n  }\n  .composer button{\n    border:none; background:var(--ink); color:var(--paper); font-family:'JetBrains Mono',monospace;\n    font-size:.78rem; letter-spacing:.05em; text-transform:uppercase; padding:0 18px; border-radius:3px; cursor:pointer;\n  }\n  .composer button:hover{ background:var(--amber-deep); }\n  .composer button:disabled{ background:var(--rule); cursor:not-allowed; }\n\n  .rail{\n    border-left:1px solid var(--rule); padding:24px 18px; position:relative;\n    font-family:'JetBrains Mono',monospace;\n  }\n  .rail-title{ font-size:.68rem; letter-spacing:.12em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:14px; }\n  .tag{\n    display:block; background:var(--teal-soft); border:1px solid var(--teal); color:var(--teal);\n    font-size:.72rem; padding:7px 9px; border-radius:3px; margin-bottom:8px;\n    animation: tagIn .3s ease;\n  }\n  .tag.done{ opacity:.55; }\n  .tag .n{ font-weight:700; margin-right:5px; }\n  @keyframes tagIn{ from{opacity:0; transform:translateX(8px);} to{opacity:1; transform:none;} }\n  .rail-empty{ color:var(--rule); font-size:.74rem; }\n\n  .session{ font-size:.66rem; color:var(--ink-soft); }\n</style>\n</head>\n<body>\n  <header>\n    <h1>📓 Field Notes — Agentic Research Assistant</h1>\n    <div class=\"meta\" id=\"status\">connecting…</div>\n  </header>\n\n  <div class=\"layout\">\n    <div class=\"transcript\" id=\"transcript\">\n      <div class=\"starter-row\" id=\"starters\">\n        <div class=\"starter\" data-q=\"What is ReAct and how does it relate to tool use?\">What is ReAct?</div>\n        <div class=\"starter\" data-q=\"What's 24 * 17, and what does RAG stand for?\">Quick math + RAG def</div>\n        <div class=\"starter\" data-q=\"What's the latest news about open-weight AI models?\">Latest AI news</div>\n        <div class=\"starter\" data-q=\"Explain the difference between fine-tuning and in-context learning.\">Fine-tuning vs ICL</div>\n      </div>\n    </div>\n    <aside class=\"rail\">\n      <div class=\"rail-title\">Citations &amp; tool calls</div>\n      <div id=\"rail-content\"><div class=\"rail-empty\">— none yet —</div></div>\n    </aside>\n  </div>\n\n  <div class=\"composer\">\n    <div class=\"composer-inner\">\n      <form id=\"form\">\n        <input type=\"text\" id=\"input\" placeholder=\"Ask a research question…\" autocomplete=\"off\" />\n        <button type=\"submit\" id=\"send\">Send</button>\n      </form>\n    </div>\n  </div>\n\n<script>\n  // Base URL: same origin by default. If this file is opened standalone\n  // (not served by the FastAPI app), edit BASE_URL to your ngrok URL.\n  const BASE_URL = window.location.origin.startsWith(\"file\") ? \"PASTE_YOUR_NGROK_URL_HERE\" : window.location.origin;\n  let sessionId = crypto.randomUUID();\n  let tagCounter = 0;\n\n  const transcript = document.getElementById('transcript');\n  const railContent = document.getElementById('rail-content');\n  const statusEl = document.getElementById('status');\n  const form = document.getElementById('form');\n  const input = document.getElementById('input');\n  const sendBtn = document.getElementById('send');\n\n  fetch(BASE_URL + '/health').then(r => r.json())\n    .then(d => statusEl.textContent = `model: ${d.model} · ${d.tools.length} tools · session ${sessionId.slice(0,8)}`)\n    .catch(() => statusEl.textContent = 'offline — check BASE_URL');\n\n  document.getElementById('starters').addEventListener('click', (e) => {\n    const q = e.target.getAttribute('data-q');\n    if (q) { input.value = q; form.requestSubmit(); }\n  });\n\n  function addMessage(role, text) {\n    const div = document.createElement('div');\n    div.className = 'msg ' + role;\n    div.innerHTML = `<span class=\"role\">${role === 'user' ? 'You' : 'Assistant'}</span><div class=\"bubble\"></div>`;\n    div.querySelector('.bubble').textContent = text;\n    transcript.appendChild(div);\n    transcript.scrollTop = transcript.scrollHeight;\n    return div.querySelector('.bubble');\n  }\n\n  function addTag(label, done=false) {\n    tagCounter += 1;\n    const tag = document.createElement('div');\n    tag.className = 'tag' + (done ? ' done' : '');\n    tag.innerHTML = `<span class=\"n\">[${tagCounter}]</span>${label}`;\n    if (railContent.querySelector('.rail-empty')) railContent.innerHTML = '';\n    railContent.appendChild(tag);\n    railContent.scrollTop = railContent.scrollHeight;\n    return tag;\n  }\n\n  form.addEventListener('submit', (e) => {\n    e.preventDefault();\n    const q = input.value.trim();\n    if (!q) return;\n    document.getElementById('starters').remove();\n    addMessage('user', q);\n    input.value = '';\n    sendBtn.disabled = true;\n\n    const bubble = addMessage('assistant', '');\n    const typing = document.createElement('span');\n    typing.className = 'typing';\n    typing.innerHTML = '<span></span><span></span><span></span>';\n    bubble.appendChild(typing);\n\n    let answer = '';\n    const url = `${BASE_URL}/research/stream?query=${encodeURIComponent(q)}&session_id=${sessionId}`;\n    const es = new EventSource(url);\n\n    es.onmessage = (ev) => {\n      const data = JSON.parse(ev.data);\n      if (data.type === 'token') {\n        if (bubble.contains(typing)) bubble.removeChild(typing);\n        answer += data.content;\n        bubble.textContent = answer;\n      } else if (data.type === 'tool_call') {\n        addTag(data.tool);\n      } else if (data.type === 'tool_done') {\n        const tags = railContent.querySelectorAll('.tag');\n        const last = tags[tags.length - 1];\n        if (last) last.classList.add('done');\n      } else if (data.type === 'done') {\n        if (data.answer) { answer = data.answer; bubble.textContent = answer; }\n        es.close();\n        sendBtn.disabled = false;\n      } else if (data.type === 'error') {\n        bubble.textContent = 'Error: ' + data.message;\n        es.close();\n        sendBtn.disabled = false;\n      }\n      transcript.scrollTop = transcript.scrollHeight;\n    };\n\n    es.onerror = () => {\n      if (bubble.contains(typing)) bubble.removeChild(typing);\n      if (!answer) bubble.textContent = '⚠️ Connection lost. Check that the backend is running and BASE_URL is correct.';\n      es.close();\n      sendBtn.disabled = false;\n    };\n  });\n</script>\n</body>\n</html>\n\"\"\"\n\n@app.get(\"/\", response_class=HTMLResponse)\ndef serve_ui():\n    return CHAT_UI_HTML\n\n# Also write a standalone copy to disk for use outside this FastAPI server.\nwith open(\"chat_ui.html\", \"w\") as f:\n    f.write(CHAT_UI_HTML)\n\nprint(\"✅ UI route added at GET / and written to ./chat_ui.html\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T22:05:12.653138Z","iopub.execute_input":"2026-06-25T22:05:12.653431Z","iopub.status.idle":"2026-06-25T22:05:12.666391Z","shell.execute_reply.started":"2026-06-25T22:05:12.653402Z","shell.execute_reply":"2026-06-25T22:05:12.665420Z"}},"outputs":[{"name":"stdout","text":"✅ UI route added at GET / and written to ./chat_ui.html\n","output_type":"stream"}],"execution_count":13},{"id":"59406c83","cell_type":"markdown","source":"## Cell 11 — Launch Server (ngrok tunnel + uvicorn)\n\nThis prints the **public URL** you'll use for:\n- Opening the Field Notes UI directly in a browser (`<public-url>/`)\n- Pasting into the n8n `HTTP Request` node's URL field (`<public-url>/research`)\n- Testing with `curl` / Postman\n\n> Kaggle kernels don't have a stable public address, hence the tunnel. If you don't have an ngrok auth token, an anonymous tunnel is used (works, but rate-limited and the URL changes every restart — set `NGROK_AUTH_TOKEN` in Kaggle Secrets for a more stable session). A Cloudflare Tunnel (`cloudflared`) is a no-account alternative if you prefer not to use ngrok at all.","metadata":{}},{"id":"85a763d0","cell_type":"code","source":"# %% Cell 11: Launch server\nimport nest_asyncio\nimport uvicorn\nimport threading\nfrom pyngrok import ngrok\n\nnest_asyncio.apply()\n\nif NGROK_AUTH_TOKEN:\n    ngrok.set_auth_token(NGROK_AUTH_TOKEN)\n\nPORT = 8000\npublic_tunnel = ngrok.connect(PORT, \"http\")\nPUBLIC_URL = public_tunnel.public_url\n\nprint(\"=\" * 70)\nprint(f\"🌐 Public URL:        {PUBLIC_URL}\")\nprint(f\"🤖 LLM:               {LLM_PROVIDER} / {AGENT_MODEL}\")\nprint(f\"🖥️  Field Notes UI:    {PUBLIC_URL}/\")\nprint(f\"🔗 n8n HTTP endpoint: {PUBLIC_URL}/research\")\nprint(f\"❤️  Health check:      {PUBLIC_URL}/health\")\nprint(\"=\" * 70)\nprint(\"Paste the n8n HTTP endpoint into n8n_workflow.json's HTTP Request node,\")\nprint(\"or open the Field Notes UI link directly in your browser to test now.\")\n\ndef _run():\n    uvicorn.run(app, host=\"0.0.0.0\", port=PORT, log_level=\"warning\")\n\nserver_thread = threading.Thread(target=_run, daemon=True)\nserver_thread.start()\n\nprint(\"\\n✅ Server running in a background thread. Keep this notebook cell's\")\nprint(\"   kernel alive to keep the tunnel + API up.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-25T22:05:12.667723Z","iopub.execute_input":"2026-06-25T22:05:12.668107Z","iopub.status.idle":"2026-06-25T22:05:14.915961Z","shell.execute_reply.started":"2026-06-25T22:05:12.668065Z","shell.execute_reply":"2026-06-25T22:05:14.914424Z"}},"outputs":[{"name":"stdout","text":"======================================================================                              \n🌐 Public URL:        https://hedge-gravity-jester.ngrok-free.dev\n🤖 LLM:               gemini / gemini-2.5-flash\n🖥️  Field Notes UI:    https://hedge-gravity-jester.ngrok-free.dev/\n🔗 n8n HTTP endpoint: https://hedge-gravity-jester.ngrok-free.dev/research\n❤️  Health check:      https://hedge-gravity-jester.ngrok-free.dev/health\n======================================================================\nPaste the n8n HTTP endpoint into n8n_workflow.json's HTTP Request node,\nor open the Field Notes UI link directly in your browser to test now.\n\n✅ Server running in a background thread. Keep this notebook cell's\n   kernel alive to keep the tunnel + API up.\n","output_type":"stream"}],"execution_count":14},{"id":"125de4d6","cell_type":"markdown","source":"## Verification Checklist\n\nRun these after Cell 11:\n\n1. **Health check** — `GET {PUBLIC_URL}/health` → `{\"status\": \"ok\", ...}`\n2. **Field Notes UI** — open `{PUBLIC_URL}/` in a browser, click a starter card, watch tokens stream in and citation tags appear in the right margin.\n3. **Direct API call** —\n   ```bash\n   curl -X POST {PUBLIC_URL}/research \\\n     -H \"Content-Type: application/json\" \\\n     -d '{\"query\": \"What is ReAct?\"}'\n   ```\n4. **Session memory** — ask a follow-up question reusing the same `session_id` and confirm the agent remembers prior context (try it in the UI — it reuses one `session_id` for the whole page session).\n5. **n8n** — import `n8n_workflow.json`, replace the placeholder URL with `{PUBLIC_URL}/research`, activate, and chat through n8n's built-in chat widget.\n6. **Mini-eval** — run `run_mini_eval()` from Cell 8 and confirm accuracy is reasonable (target ≥ 70% on this 20-question set; results vary slightly run to run since the LLM judge is itself probabilistic).\n","metadata":{}}]}
